{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VowCue",
  "version": "0.1.3",
  "identifier": "com.vowcue.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "python3 -m http.server 4173",
    "devUrl": "http://localhost:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "VowCue",
        "width": 1280,
        "height": 900,
        "minWidth": 980,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
